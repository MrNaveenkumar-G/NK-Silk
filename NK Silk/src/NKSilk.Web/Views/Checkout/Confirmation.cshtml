@model OrderDetailVm
@{
    ViewData["Title"] = "Order Confirmed";
}
<div class="container py-5">
    <div class="text-center mb-4">
        <div class="display-5 text-success">✓</div>
        <h1 class="h4">Thank you! Your order is confirmed.</h1>
        <p class="text-muted">Order <strong>@Model.OrderNumber</strong> placed on @Model.PlacedAtUtc.ToLocalTime().ToString("dd MMM yyyy, h:mm tt")</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span>Status</span>
                        <partial name="_OrderStatusBadge" model="Model.Status" />
                    </div>
                    @foreach (var line in Model.Lines)
                    {
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@line.ProductName <span class="text-muted">@line.ColorName @(string.IsNullOrEmpty(line.SizeName) ? "" : "/ " + line.SizeName) × @line.Quantity</span></span>
                            <span>₹@line.LineTotal.ToString("N0")</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between"><span>Subtotal</span><span>₹@Model.SubTotal.ToString("N0")</span></div>
                    <div class="d-flex justify-content-between"><span>Shipping</span><span>@(Model.ShippingFee == 0 ? "FREE" : "₹" + Model.ShippingFee.ToString("N0"))</span></div>
                    <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>₹@Model.GrandTotal.ToString("N0")</span></div>
                    <hr />
                    <p class="small mb-1"><strong>Ship to:</strong> @Model.ShipToName, @Model.ShipToPhone</p>
                    <p class="small text-muted mb-1">@Model.ShipToAddress</p>
                    <p class="small mb-0"><strong>Payment:</strong> @Model.PaymentMethod (@Model.PaymentStatus)</p>
                </div>
            </div>
            <div class="text-center mt-3">
                <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-dark">View my orders</a>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-accent">Continue shopping</a>
            </div>
        </div>
    </div>
</div>
