@model RegisterVm
@{
    ViewData["Title"] = "Create Account";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-1 text-center">Create your account</h1>
                    <p class="text-muted text-center small mb-4">Join NK Silk for faster checkout & order tracking</p>

                    <form asp-action="Register" asp-route-returnUrl="@returnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" autocomplete="name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" autocomplete="tel" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-sm-6 mb-3">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-accent w-100">Create account</button>
                    </form>

                    <p class="text-center small mt-3 mb-0">
                        Already have an account?
                        <a asp-action="Login" asp-route-returnUrl="@returnUrl">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
