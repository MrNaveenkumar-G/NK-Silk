@model ForgotPasswordVm
@{
    ViewData["Title"] = "Forgot password";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-1 text-center">Forgot your password?</h1>
                    <p class="text-muted text-center small mb-4">Enter your email and we'll send a reset link.</p>
                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-accent w-100">Send reset link</button>
                    </form>
                    <p class="text-center small mt-3 mb-0"><a asp-action="Login">Back to sign in</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
