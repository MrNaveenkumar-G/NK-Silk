@model IReadOnlyList<OrderListItemVm>
@{
    ViewData["Title"] = "My Orders";
}
<div class="container py-4">
    <h1 class="h4 mb-4">My Orders</h1>

    @if (Model.Count == 0)
    {
        <div class="alert alert-light border text-center py-5">
            You haven't placed any orders yet. <a asp-controller="Catalog" asp-action="Index">Start shopping →</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr><th>Order #</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@o.OrderNumber</td>
                            <td>@o.PlacedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>@o.ItemCount</td>
                            <td>₹@o.GrandTotal.ToString("N0")</td>
                            <td><partial name="_OrderStatusBadge" model="o.Status" /></td>
                            <td><a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@o.OrderNumber">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
