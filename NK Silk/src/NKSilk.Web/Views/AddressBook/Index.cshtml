@model IReadOnlyList<AddressVm>
@{
    ViewData["Title"] = "My Addresses";
}
<div class="container py-4" style="max-width:820px">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">My Addresses</h1>
        <a class="btn btn-sm btn-accent" asp-action="Edit">+ Add address</a>
    </div>

    @if (TempData["Success"] is string ok) { <div class="alert alert-success py-2">@ok</div> }

    @if (Model.Count == 0)
    {
        <div class="alert alert-light border text-center py-5">No saved addresses yet.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var a in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">@a.ContactName</span>
                                @if (a.IsDefault) { <span class="badge bg-success">Default</span> }
                            </div>
                            <p class="small text-muted mb-1">@a.PhoneNumber</p>
                            <p class="small mb-3">@a.OneLine</p>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@a.Id">Edit</a>
                                @if (!a.IsDefault)
                                {
                                    <form asp-action="SetDefault" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@a.Id" /><button class="btn btn-sm btn-outline-secondary">Make default</button></form>
                                }
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this address?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@a.Id" /><button class="btn btn-sm btn-outline-danger">Delete</button></form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
