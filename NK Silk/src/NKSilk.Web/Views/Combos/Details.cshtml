@model ComboDetailVm
@{
    ViewData["Title"] = Model.Name;
}
<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-action="Index">Combo Packs</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-5">
            <img src="@(Model.ImageUrl ?? "/img/product-placeholder.svg")" class="img-fluid rounded" alt="@Model.Name" />
        </div>
        <div class="col-md-7">
            <h1 class="h4">@Model.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Description)) { <p class="text-muted">@Model.Description</p> }

            <div class="d-flex align-items-baseline gap-2 my-2">
                <span class="h4 mb-0">₹@Model.ComboPrice.ToString("N0")</span>
                @if (Model.RegularPrice > Model.ComboPrice)
                {
                    <span class="text-muted text-decoration-line-through">₹@Model.RegularPrice.ToString("N0")</span>
                    <span class="badge bg-success">Save ₹@Model.Savings.ToString("N0")</span>
                }
            </div>

            <h2 class="h6 mt-3">What's in the box</h2>
            <ul class="list-group mb-3">
                @foreach (var i in Model.Items)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@i.ProductSlug">@i.ProductName</a>
                            <span class="text-muted small">× @i.Quantity</span>
                        </span>
                        <span>₹@((i.UnitPrice * i.Quantity).ToString("N0"))</span>
                    </li>
                }
            </ul>

            <form asp-action="AddToCart" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="comboId" value="@Model.Id" />
                <button class="btn btn-accent">Add combo to cart</button>
            </form>
            <p class="form-text">The bundle price is applied automatically in your cart when all items are present.</p>
        </div>
    </div>
</div>
