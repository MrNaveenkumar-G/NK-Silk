@model NotificationListVm
@{
    ViewData["Title"] = "Notifications";
    string Icon(NotificationType t) => t switch
    {
        NotificationType.OrderPlaced => "🛍️",
        NotificationType.OrderStatusChanged => "🚚",
        NotificationType.PaymentReceived => "💳",
        NotificationType.ReturnRequested => "↩️",
        NotificationType.ReturnUpdate => "🔄",
        _ => "🔔"
    };
}
<div class="container py-4" style="max-width:760px">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Notifications</h1>
        @if (Model.UnreadCount > 0)
        {
            <form asp-action="MarkAllRead" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-secondary">Mark all read</button>
            </form>
        }
    </div>

    @if (Model.IsEmpty)
    {
        <div class="alert alert-light border text-center py-5">You have no notifications yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in Model.Items)
            {
                <a asp-action="Open" asp-route-id="@n.Id"
                   class="list-group-item list-group-item-action @(n.IsRead ? "" : "list-group-item-light")">
                    <div class="d-flex w-100 justify-content-between">
                        <span class="fw-@(n.IsRead ? "normal" : "bold")">@Icon(n.Type) @n.Title</span>
                        <small class="text-muted">@n.CreatedAtUtc.ToLocalTime().ToString("dd MMM, h:mm tt")</small>
                    </div>
                    <div class="small text-muted">@n.Message</div>
                </a>
            }
        </div>
    }
</div>
