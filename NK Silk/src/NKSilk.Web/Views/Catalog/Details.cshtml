@model ProductDetailVm
@{
    ViewData["Title"] = Model.Name;
    var canonical = $"{Context.Request.Scheme}://{Context.Request.Host}/Catalog/Details/{Model.Slug}";
    var price = (Model.HasOffer ? Model.OfferPrice!.Value : Model.BasePrice).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    var inStock = Model.Variants.Any(v => v.Available > 0);
}

@section Head {
    <link rel="canonical" href="@canonical" />
    <meta name="description" content="@(Model.ShortDescription ?? Model.Name)" />
    <meta property="og:title" content="@Model.Name" />
    <meta property="og:type" content="product" />
    @if (Model.ImageUrls.Count > 0)
    {
        <meta property="og:image" content="@Model.ImageUrls[0]" />
    }
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org/",
        "@@type": "Product",
        "name": @Json.Serialize(Model.Name),
        "description": @Json.Serialize(Model.ShortDescription ?? Model.Description ?? Model.Name),
        "category": @Json.Serialize(Model.CategoryName ?? ""),
        @if (Model.ReviewCount > 0)
        {
            <text>"aggregateRating": { "@@type": "AggregateRating", "ratingValue": "@Model.AverageRating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)", "reviewCount": "@Model.ReviewCount" },</text>
        }
        "offers": {
            "@@type": "Offer",
            "priceCurrency": "INR",
            "price": "@price",
            "availability": "@(inStock ? "https://schema.org/InStock" : "https://schema.org/OutOfStock")",
            "url": "@canonical"
        }
    }
    </script>
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index">Shop</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-6">
            <div id="pdpCarousel" class="carousel slide nk-pdp-gallery" data-bs-ride="false">
                <div class="carousel-inner rounded">
                    @{ var imgs = Model.ImageUrls.Count > 0 ? Model.ImageUrls : new List<string> { "/img/product-placeholder.svg" }; }
                    @for (var i = 0; i < imgs.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@imgs[i]" class="d-block w-100" alt="@Model.Name">
                        </div>
                    }
                </div>
                @if (imgs.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#pdpCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#pdpCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                }
            </div>
        </div>

        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.BrandName))
            {
                <small class="text-muted text-uppercase">@Model.BrandName</small>
            }
            <h1 class="h3">@Model.Name</h1>
            @if (Model.ReviewCount > 0)
            {
                <div class="text-warning mb-2">★ @Model.AverageRating.ToString("0.0") <span class="text-muted small">(@Model.ReviewCount reviews)</span></div>
            }
            <p class="text-muted">@Model.ShortDescription</p>

            <div class="d-flex align-items-baseline gap-2 mb-1">
                @if (Model.HasOffer)
                {
                    <span class="h4 mb-0 text-danger">₹@Model.OfferPrice!.Value.ToString("N0")</span>
                    <span class="text-muted text-decoration-line-through">₹@Model.BasePrice.ToString("N0")</span>
                }
                else
                {
                    <span class="h4 mb-0">₹@Model.BasePrice.ToString("N0")</span>
                    @if (Model.MrpPrice is > 0 && Model.MrpPrice > Model.BasePrice)
                    {
                        <span class="text-muted text-decoration-line-through">₹@Model.MrpPrice.Value.ToString("N0")</span>
                    }
                }
            </div>
            @if (Model.HasOffer && !string.IsNullOrEmpty(Model.OfferTitle))
            {
                <p class="text-danger small mb-3">🎉 @Model.OfferTitle applied</p>
            }
            else { <div class="mb-3"></div> }

            @if (Model.Variants.Count > 0)
            {
                <form id="addToCartForm" class="mb-3">
                    <label class="form-label fw-semibold">Select option</label>
                    <select id="variantSelect" class="form-select mb-3" required>
                        @foreach (var v in Model.Variants)
                        {
                            var label = string.Join(" / ", new[] { v.ColorName, v.SizeName }.Where(s => !string.IsNullOrEmpty(s)));
                            if (string.IsNullOrEmpty(label)) { label = v.Sku; }
                            <option value="@v.Id" data-stock="@v.Available">
                                @label — ₹@v.Price.ToString("N0") @(v.Available <= 0 ? "(Out of stock)" : "")
                            </option>
                        }
                    </select>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="number" id="qtyInput" class="form-control" style="max-width:90px" value="1" min="1" />
                        <button type="submit" class="btn btn-accent flex-grow-1">Add to Cart</button>
                    </div>
                    <div id="addMsg" class="small mt-2"></div>
                </form>
            }
            else
            {
                <div class="alert alert-warning">Currently unavailable.</div>
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <button id="wishlistBtn" type="button" class="btn btn-outline-dark btn-sm mb-3" data-product-id="@Model.Id" data-saved="@Model.InWishlist.ToString().ToLower()">
                    <span class="heart">@(Model.InWishlist ? "♥" : "♡")</span>
                    <span class="label">@(Model.InWishlist ? "In wishlist" : "Add to wishlist")</span>
                </button>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Url.Action("Details", "Catalog", new { id = Model.Slug })"
                   class="btn btn-outline-dark btn-sm mb-3">♡ Add to wishlist</a>
            }

            <ul class="list-group list-group-flush nk-spec">
                @if (!string.IsNullOrEmpty(Model.FabricType)) { <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Fabric</span><span>@Model.FabricType</span></li> }
                @if (!string.IsNullOrEmpty(Model.MaterialComposition)) { <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Composition</span><span>@Model.MaterialComposition</span></li> }
                @if (Model.Gsm.HasValue) { <li class="list-group-item d-flex justify-content-between"><span class="text-muted">GSM</span><span>@Model.Gsm</span></li> }
                @if (!string.IsNullOrEmpty(Model.WashCare)) { <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Wash Care</span><span>@Model.WashCare</span></li> }
                @if (!string.IsNullOrEmpty(Model.Occasion)) { <li class="list-group-item d-flex justify-content-between"><span class="text-muted">Occasion</span><span>@Model.Occasion</span></li> }
            </ul>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="mt-5">
            <h2 class="h5">Product Details</h2>
            <p class="text-muted">@Model.Description</p>
        </div>
    }

    @* ---------------- Reviews ---------------- *@
    <div class="mt-5">
        <h2 class="h5 mb-3">Customer Reviews
            @if (Model.ReviewCount > 0) { <small class="text-warning">★ @Model.AverageRating.ToString("0.0")</small> }
        </h2>

        @if (TempData["ReviewMsg"] is string rmsg) { <div class="alert alert-success py-2">@rmsg</div> }
        @if (TempData["ReviewError"] is string rerr) { <div class="alert alert-danger py-2">@rerr</div> }

        <div class="row g-4">
            <div class="col-lg-7">
                @if (Model.Reviews.Count == 0)
                {
                    <p class="text-muted">No reviews yet. Be the first to review this product.</p>
                }
                else
                {
                    foreach (var r in Model.Reviews)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <div class="text-warning">@(new string('★', r.Rating))<span class="text-muted">@(new string('☆', 5 - r.Rating))</span></div>
                            @if (!string.IsNullOrEmpty(r.Title)) { <div class="fw-semibold">@r.Title</div> }
                            <p class="mb-1 small">@r.Comment</p>
                            <small class="text-muted">@r.CustomerName · @r.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</small>
                        </div>
                    }
                }
            </div>
            <div class="col-lg-5">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="card">
                        <div class="card-body">
                            <h3 class="h6">Write a review</h3>
                            <form asp-controller="Reviews" asp-action="Create" asp-route-slug="@Model.Slug" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ProductId" value="@Model.Id" />
                                <div class="mb-2">
                                    <label class="form-label small mb-0">Rating</label>
                                    <select name="Rating" class="form-select form-select-sm">
                                        @for (var i = 5; i >= 1; i--) { <option value="@i">@i ★</option> }
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <input name="Title" class="form-control form-control-sm" placeholder="Title (optional)" />
                                </div>
                                <div class="mb-2">
                                    <textarea name="Comment" rows="3" class="form-control form-control-sm" placeholder="Your experience..."></textarea>
                                </div>
                                <button class="btn btn-sm btn-accent w-100">Submit review</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <p class="small text-muted"><a asp-controller="Account" asp-action="Login">Sign in</a> to write a review.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('addToCartForm')?.addEventListener('submit', function (e) {
            e.preventDefault();
            const variantId = document.getElementById('variantSelect').value;
            const qty = parseInt(document.getElementById('qtyInput').value) || 1;
            NKSilk.addToCart(variantId, qty, document.getElementById('addMsg'));
        });

        // Wishlist toggle
        (function () {
            var btn = document.getElementById('wishlistBtn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                NKSilk.toggleWishlist(btn.getAttribute('data-product-id'), function (res) {
                    btn.querySelector('.heart').textContent = res.saved ? '♥' : '♡';
                    btn.querySelector('.label').textContent = res.saved ? 'In wishlist' : 'Add to wishlist';
                    NKSilk.setWishlistBadge(res.count);
                });
            });
        })();
    </script>
}
