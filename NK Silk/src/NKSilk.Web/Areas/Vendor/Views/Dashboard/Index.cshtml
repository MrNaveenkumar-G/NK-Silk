@model VendorDashboardVm
@{
    ViewData["Title"] = "Seller Dashboard";
}

<h1 class="h5 mb-3">@Model.VendorName</h1>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3"><div class="card stat-card p-3"><div class="stat-value">@Model.ProductCount</div><div class="stat-label">@Model.ActiveProductCount active products</div></div></div>
    <div class="col-6 col-lg-3"><div class="card stat-card p-3"><div class="stat-value">@Model.UnitsSold</div><div class="stat-label">Units sold</div></div></div>
    <div class="col-6 col-lg-3"><div class="card stat-card p-3"><div class="stat-value">₹@Model.GrossSales.ToString("N0")</div><div class="stat-label">Gross sales</div></div></div>
    <div class="col-6 col-lg-3"><div class="card stat-card p-3"><div class="stat-value">@Model.LowStockCount</div><div class="stat-label">Low-stock variants</div></div></div>
</div>

<div class="card" style="max-width:480px">
    <div class="card-header bg-white fw-semibold">Payout summary</div>
    <div class="card-body">
        <div class="d-flex justify-content-between"><span>Gross sales</span><span>₹@Model.GrossSales.ToString("N0")</span></div>
        <div class="d-flex justify-content-between text-muted"><span>Commission (@Model.CommissionRate.ToString("0.##")%)</span><span>-₹@Model.Commission.ToString("N0")</span></div>
        <hr />
        <div class="d-flex justify-content-between fw-bold"><span>Net payout</span><span>₹@Model.NetPayout.ToString("N0")</span></div>
    </div>
</div>
