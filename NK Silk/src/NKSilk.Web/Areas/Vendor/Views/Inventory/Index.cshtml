@model IReadOnlyList<AdminInventoryItemVm>
@{
    ViewData["Title"] = "Inventory";
}

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Product</th><th>SKU</th><th>Variant</th><th>Available</th><th style="width:280px">Set stock</th></tr></thead>
            <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td class="ps-3">@i.ProductName</td>
                    <td class="small">@i.Sku</td>
                    <td class="small">@i.ColorName @(string.IsNullOrEmpty(i.SizeName) ? "" : "/ " + i.SizeName)</td>
                    <td>@(i.QuantityOnHand - i.QuantityReserved)</td>
                    <td>
                        <form asp-action="Update" method="post" class="d-flex gap-1 align-items-center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="variantId" value="@i.VariantId" />
                            <input type="number" name="quantityOnHand" value="@i.QuantityOnHand" min="0" class="form-control form-control-sm" style="width:90px" title="On hand" />
                            <input type="number" name="reorderLevel" value="@i.ReorderLevel" min="0" class="form-control form-control-sm" style="width:90px" title="Reorder level" />
                            <button class="btn btn-sm btn-accent">Save</button>
                        </form>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No variants to manage.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
