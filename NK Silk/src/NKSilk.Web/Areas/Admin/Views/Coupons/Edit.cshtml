@model AdminCouponVm
@{
    ViewData["Title"] = Model.Id == 0 ? "New Coupon" : "Edit Coupon";
}

<form asp-action="Edit" method="post" style="max-width:720px">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TimesUsed" />

    <div class="card">
        <div class="card-body row">
            <div class="col-sm-6 mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control text-uppercase" placeholder="e.g. FESTIVE10" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>
            <div class="col-sm-6 mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
            </div>

            <div class="col-sm-4 mb-3">
                <label asp-for="DiscountType" class="form-label"></label>
                <select asp-for="DiscountType" class="form-select" asp-items="Html.GetEnumSelectList<DiscountType>()"></select>
            </div>
            <div class="col-sm-4 mb-3">
                <label asp-for="DiscountValue" class="form-label"></label>
                <input asp-for="DiscountValue" class="form-control" />
                <span asp-validation-for="DiscountValue" class="text-danger small"></span>
            </div>
            <div class="col-sm-4 mb-3">
                <label asp-for="MaxDiscountAmount" class="form-label"></label>
                <input asp-for="MaxDiscountAmount" class="form-control" />
            </div>

            <div class="col-sm-4 mb-3">
                <label asp-for="MinOrderAmount" class="form-label"></label>
                <input asp-for="MinOrderAmount" class="form-control" />
            </div>
            <div class="col-sm-4 mb-3">
                <label asp-for="StartsAtUtc" class="form-label"></label>
                <input asp-for="StartsAtUtc" type="date" class="form-control" />
            </div>
            <div class="col-sm-4 mb-3">
                <label asp-for="EndsAtUtc" class="form-label"></label>
                <input asp-for="EndsAtUtc" type="date" class="form-control" />
            </div>

            <div class="col-sm-4 mb-3">
                <label asp-for="UsageLimit" class="form-label"></label>
                <input asp-for="UsageLimit" class="form-control" placeholder="unlimited" />
            </div>
            <div class="col-sm-8 mb-3 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white">
            <button type="submit" class="btn btn-accent">Save Coupon</button>
            <a asp-action="Index" class="btn btn-link">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
