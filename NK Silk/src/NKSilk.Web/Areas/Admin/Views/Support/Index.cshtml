@model IReadOnlyList<SupportTicketListItemVm>
@{
    ViewData["Title"] = "Support";
    var status = ViewData["Status"] as TicketStatus?;
}

<div class="mb-3 d-flex gap-1 flex-wrap">
    <a class="btn btn-sm @(status == null ? "btn-accent" : "btn-outline-secondary")" asp-action="Index">All</a>
    @foreach (var s in Enum.GetValues<TicketStatus>())
    {
        <a class="btn btn-sm @(status == s ? "btn-accent" : "btn-outline-secondary")" asp-action="Index" asp-route-status="@s">@s</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Ticket #</th><th>Subject</th><th>Customer</th><th>Category</th><th>Updated</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@t.TicketNumber</td>
                    <td>@t.Subject</td>
                    <td>@t.CustomerName</td>
                    <td class="small">@t.Category</td>
                    <td class="small">@t.LastActivityUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td><span class="badge bg-secondary">@t.Status</span></td>
                    <td><a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@t.TicketNumber">Open</a></td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No tickets in this view.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
