@model AdminDashboardVm
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-2"><div class="card stat-card p-3"><div class="stat-value">@Model.TotalProducts</div><div class="stat-label">Products</div></div></div>
    <div class="col-6 col-lg-2"><div class="card stat-card p-3"><div class="stat-value">@Model.TotalOrders</div><div class="stat-label">Orders</div></div></div>
    <div class="col-6 col-lg-2"><div class="card stat-card p-3"><div class="stat-value">@Model.TotalCustomers</div><div class="stat-label">Customers</div></div></div>
    <div class="col-6 col-lg-3"><div class="card stat-card p-3"><div class="stat-value">₹@Model.TotalRevenue.ToString("N0")</div><div class="stat-label">Revenue</div></div></div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card p-3">
            <div class="stat-value">@Model.PendingOrders <small class="text-muted fs-6">pending</small></div>
            <div class="stat-label">@Model.LowStockVariants variants low on stock</div>
        </div>
    </div>
</div>

@if (Model.PendingReturns > 0)
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
        <span>@Model.PendingReturns return request(s) awaiting review.</span>
        <a class="btn btn-sm btn-outline-dark" asp-controller="Returns" asp-action="Index" asp-route-status="@ReturnStatus.Requested">Review returns</a>
    </div>
}

<div class="card">
    <div class="card-header bg-white fw-semibold">Recent Orders</div>
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Payment</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var o in Model.RecentOrders)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@o.OrderNumber</td>
                    <td>@o.CustomerName</td>
                    <td>@o.PlacedAtUtc.ToLocalTime().ToString("dd MMM, h:mm tt")</td>
                    <td>₹@o.GrandTotal.ToString("N0")</td>
                    <td><span class="badge bg-light text-dark">@o.PaymentMethod · @o.PaymentStatus</span></td>
                    <td><partial name="_OrderStatusBadge" model="o.Status" /></td>
                    <td><a class="btn btn-sm btn-outline-secondary" asp-controller="Orders" asp-action="Details" asp-route-id="@o.OrderNumber">View</a></td>
                </tr>
            }
            @if (Model.RecentOrders.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No orders yet.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
