@model IReadOnlyList<AdminOrderListItemVm>
@{
    ViewData["Title"] = "Orders";
    var current = ViewData["Status"] as OrderStatus?;
}

<div class="mb-3 d-flex flex-wrap gap-1">
    <a class="btn btn-sm @(current == null ? "btn-accent" : "btn-outline-secondary")" asp-action="Index">All</a>
    @foreach (var s in Enum.GetValues<OrderStatus>())
    {
        <a class="btn btn-sm @(current == s ? "btn-accent" : "btn-outline-secondary")"
           asp-action="Index" asp-route-status="@s">@s</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Order #</th><th>Customer</th><th>Date</th><th>Total</th><th>Payment</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@o.OrderNumber</td>
                    <td>@o.CustomerName</td>
                    <td>@o.PlacedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>₹@o.GrandTotal.ToString("N0")</td>
                    <td><span class="badge bg-light text-dark">@o.PaymentMethod · @o.PaymentStatus</span></td>
                    <td><partial name="_OrderStatusBadge" model="o.Status" /></td>
                    <td><a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@o.OrderNumber">Manage</a></td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No orders in this view.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
