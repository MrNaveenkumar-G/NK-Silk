@model IReadOnlyList<AdminCategoryVm>
@{
    ViewData["Title"] = "Categories";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body p-0">
                <table class="table mb-0 align-middle">
                    <thead><tr><th class="ps-3">Name</th><th>Slug</th><th>Order</th><th>Products</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@c.Name</td>
                            <td><code>@c.Slug</code></td>
                            <td>@c.DisplayOrder</td>
                            <td>@c.ProductCount</td>
                            <td>@(c.IsActive ? "Active" : "Hidden")</td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No categories yet.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white fw-semibold">Add category</div>
            <div class="card-body">
                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slug (optional)</label>
                        <input name="Slug" class="form-control" placeholder="auto-generated" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Display order</label>
                        <input name="DisplayOrder" type="number" value="0" class="form-control" />
                    </div>
                    <div class="form-check mb-3">
                        <input name="IsActive" value="true" type="checkbox" class="form-check-input" checked />
                        <label class="form-check-label">Active</label>
                    </div>
                    <button class="btn btn-accent w-100">Add Category</button>
                </form>
            </div>
        </div>
    </div>
</div>
