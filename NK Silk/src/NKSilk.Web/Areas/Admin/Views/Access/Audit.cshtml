@model IReadOnlyList<AuditLogVm>
@{
    ViewData["Title"] = "Audit log";
    var entity = ViewData["Entity"] as string;
    var entities = new[] { "Product", "Order", "Coupon", "Offer", "ComboPack", "Return", "Shipment", "Customer", "Vendor", "Inventory", "Category" };
}
<h1 class="h5 mb-3">Audit log</h1>

<div class="mb-3 d-flex gap-1 flex-wrap">
    <a class="btn btn-sm @(entity == null ? "btn-accent" : "btn-outline-secondary")" asp-action="Audit">All</a>
    @foreach (var e in entities)
    {
        <a class="btn btn-sm @(entity == e ? "btn-accent" : "btn-outline-secondary")" asp-action="Audit" asp-route-entity="@e">@e</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">When</th><th>Action</th><th>Entity</th><th>Id</th><th>By</th><th>Details</th></tr></thead>
            <tbody>
            @foreach (var a in Model)
            {
                var css = a.Action switch {
                    NKSilk.Domain.Enums.AuditAction.Created => "bg-success",
                    NKSilk.Domain.Enums.AuditAction.Deleted => "bg-danger",
                    _ => "bg-info text-dark"
                };
                <tr>
                    <td class="ps-3 small text-nowrap">@a.CreatedAtUtc.ToLocalTime().ToString("dd MMM, HH:mm:ss")</td>
                    <td><span class="badge @css">@a.Action</span></td>
                    <td>@a.EntityName</td>
                    <td>@a.EntityId</td>
                    <td class="small">@a.UserName</td>
                    <td class="small text-muted">@a.Details</td>
                </tr>
            }
            @if (Model.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-4">No audit entries.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
