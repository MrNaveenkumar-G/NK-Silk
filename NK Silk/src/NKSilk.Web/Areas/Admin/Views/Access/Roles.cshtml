@model IReadOnlyList<RoleVm>
@{
    ViewData["Title"] = "Roles";
}
<h1 class="h5 mb-3">Roles &amp; Access</h1>
<p class="text-muted small">Assign roles from the <a asp-controller="Customers" asp-action="Index">Customers</a> list (Manage access). The audit trail is under <a asp-action="Audit">Audit log</a>.</p>

<div class="card" style="max-width:560px">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Role</th><th>Description</th><th>Members</th></tr></thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@r.Name</td>
                    <td class="small text-muted">@r.Description</td>
                    <td>@r.MemberCount</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
