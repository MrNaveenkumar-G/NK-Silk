@model CustomerAccessVm
@{
    ViewData["Title"] = $"Access · {Model.FullName}";
}
<a asp-controller="Customers" asp-action="Index" class="btn btn-sm btn-link px-0 mb-2">← Customers</a>
<h1 class="h5 mb-1">Manage access</h1>
<p class="text-muted small">@Model.FullName · @Model.Email</p>

<form asp-action="SetRoles" method="post" style="max-width:480px">
    @Html.AntiForgeryToken()
    <input type="hidden" name="customerId" value="@Model.CustomerId" />
    <div class="card">
        <div class="card-body">
            @foreach (var role in Model.AllRoles)
            {
                var assigned = Model.AssignedRoles.Contains(role.Name);
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" name="roles" value="@role.Name" id="role-@role.Id" @(assigned ? "checked" : "") />
                    <label class="form-check-label" for="role-@role.Id">
                        <strong>@role.Name</strong> <span class="text-muted small">— @role.Description</span>
                    </label>
                </div>
            }
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-accent">Save roles</button>
        <a class="btn btn-outline-secondary" asp-controller="Customers" asp-action="Index">Cancel</a>
    </div>
    <p class="form-text">Role changes take effect the next time the customer signs in.</p>
</form>
