@model IReadOnlyList<ReturnListItemVm>
@{
    ViewData["Title"] = "Returns";
    var status = ViewData["Status"] as ReturnStatus?;
}

<div class="mb-3 d-flex gap-1 flex-wrap">
    <a class="btn btn-sm @(status == null ? "btn-accent" : "btn-outline-secondary")" asp-action="Index">All</a>
    @foreach (var s in Enum.GetValues<ReturnStatus>())
    {
        <a class="btn btn-sm @(status == s ? "btn-accent" : "btn-outline-secondary")" asp-action="Index" asp-route-status="@s">@s</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Return #</th><th>Order #</th><th>Customer</th><th>Reason</th><th>Refund</th><th>Date</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@r.ReturnNumber</td>
                    <td>@r.OrderNumber</td>
                    <td>@r.CustomerName</td>
                    <td class="small">@r.Reason</td>
                    <td>₹@r.RefundAmount.ToString("N0")</td>
                    <td class="small">@r.RequestedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td><partial name="_ReturnStatusBadge" model="r.Status" /></td>
                    <td><a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@r.ReturnNumber">Manage</a></td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No returns in this view.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
