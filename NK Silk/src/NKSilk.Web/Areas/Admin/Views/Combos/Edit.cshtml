@model AdminComboVm
@{
    ViewData["Title"] = Model.Id == 0 ? "New combo" : "Edit combo";
}
<a asp-action="Index" class="btn btn-sm btn-link px-0 mb-2">← All combos</a>
<h1 class="h5 mb-3">@ViewData["Title"]</h1>

<form asp-action="Edit" method="post" style="max-width:680px">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label" asp-for="Name"></label>
            <input class="form-control" asp-for="Name" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="Slug"></label>
            <input class="form-control" asp-for="Slug" placeholder="auto from name" />
        </div>
        <div class="col-12">
            <label class="form-label" asp-for="Description"></label>
            <textarea class="form-control" asp-for="Description" rows="2"></textarea>
        </div>
        <div class="col-md-8">
            <label class="form-label" asp-for="ImageUrl"></label>
            <input class="form-control" asp-for="ImageUrl" placeholder="/img/combo.jpg (optional)" />
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="ComboPrice"></label>
            <input class="form-control" asp-for="ComboPrice" type="number" step="0.01" />
        </div>
        <div class="col-12">
            <label class="form-label" asp-for="ItemsCsv"></label>
            <input class="form-control" asp-for="ItemsCsv" placeholder="e.g. 1:1, 4:2" />
            <div class="form-text">Product ids with quantities. Find ids on the Products page.</div>
        </div>
        <div class="col-12">
            <div class="form-check"><input class="form-check-input" asp-for="IsActive" /><label class="form-check-label" asp-for="IsActive">Active</label></div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-accent">Save combo</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
