@model IReadOnlyList<AdminComboVm>
@{
    ViewData["Title"] = "Combo Packs";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h5 mb-0">Combo Packs</h1>
    <a class="btn btn-sm btn-accent" asp-action="Edit">+ New combo</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Name</th><th>Items</th><th>Regular</th><th>Combo price</th><th>Savings</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@c.Name</td>
                    <td>@c.ItemCount</td>
                    <td>₹@c.RegularPrice.ToString("N0")</td>
                    <td>₹@c.ComboPrice.ToString("N0")</td>
                    <td class="text-success">₹@(Math.Max(0, c.RegularPrice - c.ComboPrice).ToString("N0"))</td>
                    <td>@if (c.IsActive) { <span class="badge bg-success">Active</span> } else { <span class="badge bg-secondary">Off</span> }</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                        <form asp-action="Toggle" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@c.Id" /><button class="btn btn-sm btn-outline-secondary">@(c.IsActive ? "Disable" : "Enable")</button></form>
                    </td>
                </tr>
            }
            @if (Model.Count == 0) { <tr><td colspan="7" class="text-center text-muted py-4">No combo packs yet.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
