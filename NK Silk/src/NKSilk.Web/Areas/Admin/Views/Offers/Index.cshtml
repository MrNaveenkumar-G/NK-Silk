@model IReadOnlyList<AdminOfferVm>
@{
    ViewData["Title"] = "Offers";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h5 mb-0">Offers &amp; Campaigns</h1>
    <a class="btn btn-sm btn-accent" asp-action="Edit">+ New offer</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0 align-middle">
            <thead><tr><th class="ps-3">Title</th><th>Discount</th><th>Applies to</th><th>Window</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td class="ps-3 fw-semibold">@o.Title</td>
                    <td>@(o.OfferType == NKSilk.Domain.Enums.OfferType.PercentageOff ? $"{o.Value:0.##}%" : $"₹{o.Value:N0}") off</td>
                    <td class="small">@o.ScopeName</td>
                    <td class="small">@o.StartsAtUtc.ToLocalTime().ToString("dd MMM") – @o.EndsAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                        @if (o.IsLive) { <span class="badge bg-success">Live</span> }
                        else if (o.IsActive) { <span class="badge bg-info text-dark">Scheduled</span> }
                        else { <span class="badge bg-secondary">Off</span> }
                    </td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@o.Id">Edit</a>
                        <form asp-action="Toggle" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@o.Id" /><button class="btn btn-sm btn-outline-secondary">@(o.IsActive ? "Disable" : "Enable")</button></form>
                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this offer?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@o.Id" /><button class="btn btn-sm btn-outline-danger">Delete</button></form>
                    </td>
                </tr>
            }
            @if (Model.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-4">No offers yet.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
